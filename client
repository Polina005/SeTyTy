#include <iostream> 
#include <fstream> 
#include <string> 
#include <thread> 
#include <chrono> 
#include <conio.h> 
#include <sstream> 
#include <windows.h>

using namespace std;
using namespace std::this_thread;
using namespace std::chrono;

// Установка правильной кодировки для консоли
void setRussianConsole() {
    SetConsoleCP(1251);
    SetConsoleOutputCP(1251);
}

int main() {
    setRussianConsole();
    setlocale(LC_ALL, "rus");

    // ИСПРАВЛЕНО: используем правильный путь к рабочему столу
    const string SERVER_FILE = "C:\\Users\\Public\\Server\\server.txt";
    const string CLIENT_DIR = "C:\\Users\\Public\\Server\\";

    string nickname;
    cout << "-----------------------------\n";
    cout << "|         КЛИЕНТ            |\n";
    cout << "-----------------------------\n\n";
    cout << "Имя: ";
    cin >> nickname;

    string client_file = CLIENT_DIR + nickname + ".txt";

    string surname;
    double height, weight;
    cout << "Фамилия: ";
    cin >> surname;
    cout << "Рост (см): ";
    cin >> height;
    cout << "Вес (кг): ";
    cin >> weight;

    // Отправка запроса серверу 
    ofstream fileOTVET(SERVER_FILE, ios::app);
    if (!fileOTVET) {
        cerr << "Ошибка открытия файла сервера!" << endl;
        cout << "НАЖМИТЕ ESC ДЛЯ ВЫХОДА...";
        while (_getch() != 27) {}
        return 1;
    }

    fileOTVET << nickname << ":" << surname << " " << height << " " << weight << endl;
    fileOTVET.close();

    cout << "\nЗапрос отправлен. Ожидание ответа...\n";

    int lineCl1 = 0;
    ifstream count_file(client_file);
    string temp;
    while (getline(count_file, temp)) {
        if (!temp.empty()) lineCl1++;
    }
    count_file.close();

    bool answered = false;
    bool exitByEsc = false;
    int timeout_counter = 0;
    const int TIMEOUT_MAX = 150;

    cout << "Ожидание ответа от сервера (ESC - выход)...\n" << endl;

    while (!answered && !exitByEsc && timeout_counter < TIMEOUT_MAX) {

        if (_kbhit()) {
            if (_getch() == 27) {
                exitByEsc = true;
                break;
            }
        }

        sleep_for(milliseconds(200));
        timeout_counter++;

        int LineCl2 = 0;
        ifstream f(client_file);
        string line;
        string lastLine;

        while (getline(f, line)) {
            if (!line.empty()) {
                LineCl2++;
                lastLine = line;
            }
        }
        f.close();

        if (LineCl2 > lineCl1) {
            cout << "\n--------------------------\n";
            cout << " ПОЛУЧЕН ОТВЕТ ОТ СЕРВЕРА:\n";
            cout << "----------------------------\n";
            cout << "   " << lastLine << "\n";
            cout << "----------------------------\n\n";
            answered = true;
        }
    }

    if (exitByEsc) {
        cout << "Клиент завершил работу.\n";
    }
    else if (timeout_counter >= TIMEOUT_MAX) {
        cout << "Время ожидания истекло (30 сек).\n";
    }
    else {
        cout << "Ответ получен.\n";
    }

    cout << "\n-----------------\n";
    cout << "НАЖМИТЕ ESC ДЛЯ ВЫХОДА...";
    while (_getch() != 27) {}
}
