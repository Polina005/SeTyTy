#include <iostream> 
#include <fstream> 
#include <string> 
#include <thread> 
#include <chrono> 
#include <conio.h> 
#include <sstream> 
#include <windows.h>

using namespace std;
using namespace std::this_thread;
using namespace std::chrono;

// Установка правильной кодировки для консоли
void setRussianConsole() {
    SetConsoleCP(1251);
    SetConsoleOutputCP(1251);
}

// Индекс массы тела 
string imt(const string& surname, double height, double weight) {
    double imt = weight / ((height / 100) * (height / 100));

    if (imt < 18.5) return surname + ": Недостаточный вес";
    if (imt < 25) return surname + ": Нормальный вес";
    return surname + ": Избыточный вес";
}

int main() {
    setRussianConsole();
    setlocale(LC_ALL, "rus");

    // ИСПРАВЛЕНО: используем правильный путь к рабочему столу
    const string SERVER_FILE = "C:\\Users\\Public\\Server\\server.txt";
    const string CLIENT_DIR = "C:\\Users\\Public\\Server\\";
    cout << "-----------------------------\n";
    cout << "|         СЕРВЕР            |\n";
    cout << "-----------------------------\n";
    cout << "Нажмите ESC для остановки...\n\n";

    // Создание файла, если его нет 
    ofstream create(SERVER_FILE, ios::app);
    create.close();

    // Начальный размер файла 
    streampos size1 = 0;
    ifstream size_file(SERVER_FILE, ios::ate);
    if (size_file.is_open()) {
        size1 = size_file.tellg();
        size_file.close();
    }

    int total_zaprosov = 0;
    bool running = true;

    while (running) {
        if (_kbhit()) {
            int ch = _getch();
            if (ch == 27) {
                running = false;
                break;
            }
        }

        sleep_for(milliseconds(200));

        ifstream curr_file(SERVER_FILE, ios::ate);
        streampos size2 = 0;
        if (curr_file.is_open()) {
            size2 = curr_file.tellg();
            curr_file.close();
        }

        if (size2 > size1) {
            cout << "\n НОВЫЕ ЗАПРОСЫ!\n";

            ifstream read_file(SERVER_FILE);
            if (read_file.is_open()) {
                read_file.seekg(size1);

                string line;
                int count = 0;

                while (getline(read_file, line)) {
                    if (line.empty()) continue;

                    size_t colon_pos = line.find(':');
                    if (colon_pos == string::npos) {
                        cout << "Ошибка формата: " << line << endl;
                        continue;
                    }

                    string nickname = line.substr(0, colon_pos);
                    string data = line.substr(colon_pos + 1);

                    istringstream iss(data);
                    string surname;
                    double height, weight;

                    if (!(iss >> surname >> height >> weight)) {
                        cout << "Ошибка в данных от " << nickname << ": " << data << endl;
                        continue;
                    }

                    cout << "\n  Запрос " << (total_zaprosov + 1) << ":\n";
                    cout << "  Отправитель: " << nickname << "\n";
                    cout << "  Данные: " << surname << ", рост: " << height << "см, вес: " << weight << "кг\n";

                    string otvet = imt(surname, height, weight);
                    cout << "  Ответ: " << otvet << "\n";

                    // Сохраняем ответ в файл клиента
                    string client_file = CLIENT_DIR + nickname + ".txt";

                    ofstream write_file(client_file, ios::app);
                    if (write_file.is_open()) {
                        write_file << otvet << endl;
                        write_file.close();
                        cout << "Ответ сохранён\n";
                    }
                    else {
                        cout << "ОШИБКА: не удалось создать файл\n";
                    }

                    count++;
                    total_zaprosov++;
                }

                read_file.close();
                size1 = size2;
            }
        }
    }

    cout << "\n--------------------------------------\n";
    cout << "Сервер остановлен. Обработано запросов: " << total_zaprosov << "\n";
    cout << "----------------------------------------\n";
}
